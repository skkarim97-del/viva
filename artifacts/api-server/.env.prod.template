# =====================================================================
# Viva api-server .env.prod TEMPLATE
# =====================================================================
# DO NOT COMMIT a filled-in copy of this file. Use it as a checklist
# when you paste values into AWS App Runner / Secrets Manager.
#
# Filename convention: copy to .env.prod (gitignored), fill in the
# bracketed placeholders, then transcribe into App Runner.
#
# The api-server's startup assert (artifacts/api-server/src/index.ts)
# refuses to boot in production if any "REQUIRED" var is missing
# or any "MUST BE ABSENT" var is set.
# =====================================================================

# ---- REQUIRED ---------------------------------------------------------
NODE_ENV=production
PORT=8080

# Full RDS connection string. Must include sslmode=require.
# Store in Secrets Manager as `viva/prod/AWS_DATABASE_URL` and reference
# from App Runner -- never paste raw into the env panel.
AWS_DATABASE_URL=postgres://<user>:<password>@<rds-endpoint>:5432/<db>?sslmode=require

# 64 hex chars. Generate with: openssl rand -hex 32
# Store in Secrets Manager as `viva/prod/SESSION_SECRET`. Rotate on
# any suspected exposure. Must be >= 32 chars or boot fails.
SESSION_SECRET=<generate-with-openssl-rand-hex-32>

# Explicit even though prod defaults are already safe -- an explicit
# value is auditable in the App Runner config panel.
COACH_PILOT_MODE=safe
INTERVENTION_AI_MODE=fallback

# Comma-separated CIDRs / IPs allowed to hit operator-only endpoints
# (/api/internal/*). Office egress, VPN exit, or your own home IP for
# a small pilot. No spaces.
OPERATOR_ALLOWED_IPS=<ip1>,<ip2>

# Optional: pino log level. info is right for pilot.
LOG_LEVEL=info


# ---- MUST BE ABSENT IN PRODUCTION ------------------------------------
# The startup assert refuses to boot if any of these are set. Listed
# here so the operator knows NOT to add them, not as values to set.
#
# ENABLE_DEV_LOGIN        # would mount /api/dev/* in production
# OPENAI_API_KEY          # no PHI to non-BAA AI vendors
# ANTHROPIC_API_KEY       # no PHI to non-BAA AI vendors
# GEMINI_API_KEY          # no PHI to non-BAA AI vendors
# ALLOW_DEMO_SEED         # only set in the demo DB environment
# DATABASE_URL            # forces use of AWS_DATABASE_URL only
