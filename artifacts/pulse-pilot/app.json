{
  "expo": {
    "name": "Viva Ai",
    "slug": "viva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "viva",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "sullyk97",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1923"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.sullyk97.vivaai",
      "buildNumber": "13",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sullyk97.vivaai",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Viva reads Apple Health data like steps, sleep, heart rate, and workouts to personalize your treatment support.",
          "NSHealthUpdateUsageDescription": "Viva may write limited health data only if needed to support your treatment experience.",
          "background": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ac5d39aa-6233-4364-ac00-5669c1460678"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
