# /etc/caddy/Caddyfile
#
# Caddy 2 automatically obtains and renews a Let's Encrypt cert as soon as
# api.viva-ai.com resolves to this box's public IP and TCP/80 + TCP/443 are
# reachable from the internet.
#
# Tail the logs while the cert is being issued:
#   sudo journalctl -u caddy -f

{
    # Use the production CA. Switch to staging while debugging cert issues
    # to avoid hitting Let's Encrypt rate limits:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

    # Operator email for cert expiry notifications.
    email ops@viva-ai.com
}

api.viva-ai.com {
    encode gzip zstd

    # Forward every request to the Node API on localhost:8080.
    # Caddy automatically sets X-Forwarded-For / X-Forwarded-Proto, which
    # Express respects because we have app.set("trust proxy", 1).
    reverse_proxy 127.0.0.1:8080

    # Access log -- 6-year retention matches HIPAA audit requirements.
    log {
        output file /var/log/caddy/api.viva-ai.com.access.log {
            roll_size     100mb
            roll_keep     60
            roll_keep_for 8760h
        }
        format json
    }

    # Belt-and-suspenders security headers. The API also sets some of these
    # itself; Caddy's defaults are fine to override here.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "no-referrer"
        # Block this site from being framed.
        X-Frame-Options           "DENY"
    }
}
