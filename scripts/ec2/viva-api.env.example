# /etc/viva-api.env -- copy of the skeleton bootstrap.sh writes.
# Mode 0600, owned by root.

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# --- Database (AWS RDS) -----------------------------------------------------
AWS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
AWS_DB_SSL_CA_PATH=/opt/viva/rds-ca-bundle.pem

# --- Browser CORS allowlist -------------------------------------------------
# Add the dashboard origin only AFTER you cut the dashboard over (Phase 11).
# Today the dashboard is served from viva-ai.replit.app; if and when it
# moves to its own subdomain (e.g. clinic.itsviva.com) add it here too.
ALLOWED_ORIGINS=https://viva-ai.replit.app

# --- Sessions / operator auth ----------------------------------------------
SESSION_SECRET=__GENERATE_WITH_openssl_rand_hex_32__
INTERNAL_API_KEY=__GENERATE_WITH_openssl_rand_hex_32__
# EXACT IPv4 / IPv6 addresses only, comma-separated. CIDR is NOT supported
# (the implementation does set membership). Get your current IP from
# https://ifconfig.me. Re-add when your office IP changes.
INTERNAL_IP_ALLOWLIST=203.0.113.4,198.51.100.10

# --- Coach pilot mode -------------------------------------------------------
COACH_PILOT_MODE=safe

# --- Mobile associated domains JSON ----------------------------------------
APPLE_TEAM_ID=
ANDROID_APP_SIGNING_SHA256=
