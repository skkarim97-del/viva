# /etc/viva-api.env  --  EC2 environment for the Viva API server
# Mode 0600, owned by root. The systemd unit reads this file via
# EnvironmentFile=. Do NOT commit a filled-in copy of this file.

# =============================================================================
# REQUIRED -- the API will exit at boot if any of these are missing or wrong
# =============================================================================

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# --- Database (AWS RDS) ------------------------------------------------------
# Use AWS_DATABASE_URL, NOT DATABASE_URL. The SSL branch in
# lib/db/src/index.ts only activates when AWS_DATABASE_URL is set; setting
# DATABASE_URL on EC2 would silently route the API at the wrong database.
#
# COPY this value from Replit Secrets (key: AWS_DATABASE_URL):
#   1. In the Replit workspace, open the Secrets pane (left sidebar).
#   2. Find AWS_DATABASE_URL, click the eye icon to reveal.
#   3. Paste the entire postgresql://... string below.
AWS_DATABASE_URL=

# Path to the RDS CA bundle on disk. Already downloaded by bootstrap.sh.
# If this file is missing the connection falls back to no-verify (logged).
AWS_DB_SSL_CA_PATH=/opt/viva/rds-ca-bundle.pem

# --- Sessions (doctor cookie signing) ----------------------------------------
# GENERATE FRESH ON THIS BOX -- do NOT copy from Replit. EC2 is its own
# trust boundary; reusing the Replit secret means a compromise of one
# environment exposes the other.
#   openssl rand -hex 32
SESSION_SECRET=

# --- Operator endpoints (/api/internal/*) ------------------------------------
# Static bearer for operator-only routes. GENERATE FRESH ON THIS BOX.
#   openssl rand -hex 32
INTERNAL_API_KEY=

# EXACT IPv4 / IPv6 addresses only, comma-separated. CIDR ranges are NOT
# supported -- the middleware does an exact set membership check.
# Find your current public IP at https://ifconfig.me. Re-add when your
# office IP changes. If you leave this blank the operator endpoints accept
# any source IP and the server logs a loud warning at boot.
INTERNAL_IP_ALLOWLIST=

# --- Browser CORS allowlist --------------------------------------------------
# Comma-separated list of every browser origin that talks to /api.
# Mobile native fetch sends no Origin header so it is unaffected.
# Today the dashboard is served from viva-ai.replit.app; add the future
# dashboard origin (e.g. https://clinic.itsviva.com) here only AFTER you
# point that domain at this backend.
ALLOWED_ORIGINS=https://viva-ai.replit.app

# --- AI coach mode (locked to 'safe' for HIPAA pilot) ------------------------
# 'safe' rejects /coach/chat with 403 and serves /coach/structured with
# templated responses (no OpenAI call). Required for the pilot.
COACH_PILOT_MODE=safe

# =============================================================================
# STRONGLY RECOMMENDED -- the server boots without these but features break
# =============================================================================

# --- Mobile associated-domains JSON (Universal Links / App Links) ------------
# Without these, /.well-known/apple-app-site-association and
# /.well-known/assetlinks.json return 404, and patient invite links served
# from this domain will NOT auto-open the Viva app on iOS / Android.
#
# APPLE_TEAM_ID:
#   App Store Connect -> Membership Details -> Team ID
#   (10-char alphanumeric, e.g. ABCDE12345)
APPLE_TEAM_ID=

# ANDROID_APP_SIGNING_SHA256:
#   Google Play Console -> Setup -> App integrity -> App signing key
#     -> "SHA-256 certificate fingerprint"
#   (64 hex chars in colon-separated pairs, e.g. AB:CD:EF:...)
#   For EAS-managed signing: `eas credentials` -> Android -> production.
ANDROID_APP_SIGNING_SHA256=

# --- TestFlight invite landing CTA -------------------------------------------
# COPY this value from Replit Secrets (key: VIVA_TESTFLIGHT_URL).
# Falls back to the public App Store listing if unset (with a loud warn).
VIVA_TESTFLIGHT_URL=

# =============================================================================
# DO NOT SET on EC2 -- explicitly omitted, listed for clarity only
# =============================================================================
#
# DATABASE_URL                 -> Replit-managed local DB. EC2 must use
#                                  AWS_DATABASE_URL (above) only.
# OPENAI_API_KEY               -> Pilot is COACH_PILOT_MODE=safe; no OpenAI
# AI_INTEGRATIONS_OPENAI_API_KEY  call is made. The Replit-proxy key would
#                                  also fail to auth from outside Replit.
# COACH_STORE_RAW_MESSAGES     -> Dev-only debug toggle; gated on
#                                  NODE_ENV !== "production".
